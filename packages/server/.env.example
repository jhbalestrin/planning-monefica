PORT=5555
ENV=development
MONGODB_URL=mongodb://127.0.0.1:27017/planning-monefica
# Comma-separated origins when ENV is staging or production
# CORS_ORIGINS=https://hradmin.example.com,http://localhost:3000

# Auth (Epic 1 — AD-AUTH-001 / AD-AUTH-002)
JWT_SECRET=change-me-in-development-only
JWT_ACCESS_TTL_SEC=900
JWT_REFRESH_TTL_SEC=2592000
BCRYPT_ROUNDS=10
AUTH_LOGIN_MAX_ATTEMPTS=8
AUTH_LOGIN_WINDOW_SEC=900
AUTH_LOCKOUT_SEC=900
AUTH_INVITE_TOKEN_TTL_MIN=10080
AUTH_RESET_TOKEN_TTL_MIN=60
# Set true only in local dev to log reset tokens (never in prod)
AUTH_LOG_RESET_TOKEN_IN_DEV=false
# POST /api/v1/auth/dev/invite/:tenantUserId — issue invite token (dev only)
AUTH_ENABLE_DEV_INVITES=false
